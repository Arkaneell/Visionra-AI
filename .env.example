# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Model ─────────────────────────────────────────────────────────────────────
GROQ_MODEL=llama3-70b-8192
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=2048

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=true

# ── Memory ────────────────────────────────────────────────────────────────────
SESSION_HISTORY_LIMIT=20
